DEBUG = True
DB_NAME = webinar
DB_USER = postgres
DB_PASSWORD = sahand91
DB_HOST = 127.0.0.1
DB_POST = 5432
<header class="wd-head">
        {% for i in category %}
          <span class="tag">{{i}}</span>
        {% endfor %}
          <h1 class="wd-title">{{host_name}}</h1>
          <p class="wd-lead">{{w.description}}</p>
          <div class="wd-meta">
            <div><span class="k">When</span><span class="v">{{w.hosted_at}}</span></div>
{#            <div><span class="k">Length</span><span class="v">{{w.minutes}} minutes</span></div>#}
            <div><span class="k">Host</span><span class="v">{{host}}</span></div>
            <div><span class="k">Seats left</span><span class="v">{{w.stock}}</span></div>
              {% if joined %}
              <div><span class="k">Join Link</span><span class="v">{{w.link}}</span></div>
              {% endif %}
          </div>
        </header>
<form class="wd-card" id="edit-form">
        <h2 class="wd-title" style="font-size:36px">Edit webinar</h2>
        <div class="field"><label>Title</label><input name="title" value="${attr(w.title)}" required></div>
        <div class="field"><label>Description</label><textarea name="description" required>${escape(w.description)}</textarea></div>
        <div class="field-row">
          <div class="field"><label>Hosted at</label><input name="hostedAt" value="${attr(w.hostedAt)}" required></div>
          <div class="field"><label>Price (€, 0 = free)</label><input name="price" type="number" min="0" value="${w.price}"></div>
          <div class="field"><label>Tickets left</label><input name="ticketsLeft" type="number" min="0" value="${w.ticketsLeft}"></div>
        </div>
        <div class="field"><label>Hidden join link</label><input name="joinLink" value="${attr(w.joinLink || "")}" placeholder="https://..."></div>
        <div class="wd-actions">
          <button type="submit" class="btn btn-primary">Save</button>
          <button type="button" class="btn" id="cancel-btn">Cancel</button>
        </div>
      </form>